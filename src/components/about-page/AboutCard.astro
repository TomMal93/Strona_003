---
import { Image } from "astro:assets";
import SectionFrame from "../ui/SectionFrame.astro";
import PhoneButton from "../ui/PhoneButton.astro";
import PrimaryButton from "../ui/PrimaryButton.astro";
import { about } from "../../data/about";
import { company } from "../../data/company";
import portraitImage from "../../assets/hero-main-image.webp";

const page = about.page;
const emailHref = `mailto:${company.email}`;
const addressFull = `${company.address.street}, ${company.address.zip} ${company.address.city}`;
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addressFull)}`;

const socials: { label: string; href: string; icon: string }[] = [
  {
    label: "Facebook",
    href: company.social.facebook,
    icon: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  },
  {
    label: "Instagram",
    href: company.social.instagram,
    icon: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>',
  },
  {
    label: "LinkedIn",
    href: company.social.linkedin,
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 17v-7"/>',
  },
].filter((s) => s.href);
---

<SectionFrame id="wizytowka" title={page.eyebrow} shellClass="about-card-shell">
  <Fragment slot="icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="5" width="20" height="14" rx="2" />
      <path d="M2 9h20" />
      <path d="M7 14h4" />
      <path d="M14 14h3" />
    </svg>
  </Fragment>

  <div class="about-card">
    <div class="about-card__top">
      <div class="about-card__portrait">
        <Image
          src={portraitImage}
          alt={`${about.name} — ${about.role}`}
          class="about-card__image"
          loading="eager"
        />
        <div class="about-card__badge">
          <span class="about-card__badge-eyebrow">{about.role}</span>
          <span class="about-card__badge-name">{about.name}</span>
        </div>
      </div>

      <div class="about-card__panel">
        <h1 class="about-card__title">{page.headline}</h1>
        <p class="about-card__tagline" set:html={page.tagline} />

        <div class="about-card__paragraphs">
          {page.extendedParagraphs.map((p) => (
            <p class="about-card__paragraph" set:html={p} />
          ))}
        </div>

        <div class="about-card__contact">
          <div class="about-contact-row">
            <div class="about-contact-row__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div class="about-contact-row__body">
              <span class="about-contact-row__label">Telefon</span>
              <span class="about-contact-row__value">{company.phone}</span>
            </div>
            <div class="about-contact-row__action">
              <PhoneButton size="lg" showSubtext subtextLabel="Zadzwoń" />
            </div>
          </div>

          <div class="about-contact-row">
            <div class="about-contact-row__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </div>
            <div class="about-contact-row__body">
              <span class="about-contact-row__label">E-mail</span>
              <span class="about-contact-row__value">{company.email}</span>
            </div>
            <div class="about-contact-row__action">
              <PrimaryButton href={emailHref}>Wyślij wiadomość</PrimaryButton>
            </div>
          </div>

          <div class="about-contact-row">
            <div class="about-contact-row__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <div class="about-contact-row__body">
              <span class="about-contact-row__label">Biuro</span>
              <span class="about-contact-row__value">{company.address.street}</span>
              <span class="about-contact-row__value-sub">{company.address.zip} {company.address.city}</span>
            </div>
            <div class="about-contact-row__action">
              <PrimaryButton href={mapsHref}>Pokaż na mapie</PrimaryButton>
            </div>
          </div>
        </div>

        {socials.length > 0 && (
          <div class="about-card__socials">
            <span class="about-card__socials-label">{page.socialHeading}</span>
            <div class="about-card__socials-row">
              {socials.map((s) => (
                <a
                  href={s.href}
                  class="about-card__social"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={s.icon} />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <aside class="about-hours">
      <div class="about-hours__header">
        <span class="about-hours__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" />
          </svg>
        </span>
        <div class="about-hours__heading">
          <span class="about-hours__eyebrow">Dostępność</span>
          <h3 class="about-hours__title">{page.hoursTitle}</h3>
        </div>
      </div>

      <ul class="about-hours__list">
        {page.hoursRows.map((row, index) => (
          <li class:list={["about-hours__row", index === 0 && "about-hours__row--primary"]}>
            <span class="about-hours__day">{row.day}</span>
            <span class="about-hours__sep" aria-hidden="true"></span>
            <span class="about-hours__value">{row.hours}</span>
          </li>
        ))}
      </ul>

      <p class="about-hours__note">{page.hoursNote}</p>
    </aside>
  </div>
</SectionFrame>
