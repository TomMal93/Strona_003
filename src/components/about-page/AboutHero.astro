---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import PhoneButton from "../ui/PhoneButton.astro";
import { about } from "../../data/about";
import { company } from "../../data/company";
import portraitImage from "../../assets/hero-main-image.webp";

const page = about.page;

const socials: { label: string; href: string; icon: string }[] = [
  {
    label: "Facebook",
    href: company.social.facebook,
    icon: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  },
  {
    label: "Instagram",
    href: company.social.instagram,
    icon: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>',
  },
  {
    label: "LinkedIn",
    href: company.social.linkedin,
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 17v-7"/>',
  },
].filter((s) => s.href);
---

<header class="about-hero">
  <div class="about-hero__portrait">
    <Image
      src={portraitImage}
      alt={`${about.name} — ${about.role}`}
      class="about-hero__image"
      loading="eager"
    />
    <div class="about-hero__badge">
      <span class="about-hero__badge-eyebrow">{about.role}</span>
      <span class="about-hero__badge-name">{about.name}</span>
    </div>
  </div>

  <div class="about-hero__panel">
    <p class="about-hero__eyebrow">{page.eyebrow}</p>
    <h1 class="about-hero__title">{page.headline}</h1>
    <p class="about-hero__tagline" set:html={page.tagline} />

    <div class="about-hero__paragraphs">
      {page.extendedParagraphs.map((p) => (
        <p class="about-hero__paragraph" set:html={p} />
      ))}
    </div>

    <div class="about-hero__cta">
      <PhoneButton size="lg" showSubtext subtextLabel="Zadzwoń teraz" class="group" />
      <Button href="/kontakt.vcf" variant="accent" class="group">
        {page.vcardLabel}
      </Button>
    </div>

    {socials.length > 0 && (
      <div class="about-hero__socials">
        <span class="about-hero__socials-label">{page.socialHeading}</span>
        <div class="about-hero__socials-row">
          {socials.map((s) => (
            <a
              href={s.href}
              class="about-hero__social"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</header>
