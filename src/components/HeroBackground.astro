---
import { getImage } from "astro:assets";
import heroMainImage from "../assets/hero-main-image.webp";
import heroMainImageMobile from "../assets/hero-main-image-mobile.webp";

interface Props {
  variant: "mobile" | "desktop";
}

const { variant } = Astro.props;
const isMobile = variant === "mobile";

const image = await getImage({
  src: isMobile ? heroMainImageMobile : heroMainImage,
  widths: isMobile ? [480, 768] : [1024, 1440, 1920],
  sizes: isMobile ? "100vw" : "92vw",
  quality: 80,
  format: "webp",
});
---

<img
  src={image.src}
  srcset={image.srcSet.attribute}
  sizes={isMobile ? "100vw" : "92vw"}
  alt="Agent ubezpieczeniowy"
  width={image.attributes.width}
  height={image.attributes.height}
  loading="eager"
  fetchpriority="high"
  class:list={[
    "w-full object-cover brightness-110 saturate-110",
    isMobile ? "h-56 sm:h-64" : "absolute inset-0 h-full",
  ]}
/>
