---
import { getImage } from "astro:assets";
import heroMainImage from "../assets/hero-main-image.webp";
import heroMainImageMobile from "../assets/hero-main-image-mobile.webp";

const desktop = await getImage({
  src: heroMainImage,
  widths: [1024, 1440, 1920],
  sizes: "60vw",
  quality: 80,
  format: "webp",
});

const mobile = await getImage({
  src: heroMainImageMobile,
  widths: [480, 768],
  sizes: "92vw",
  quality: 80,
  format: "webp",
});
---

<picture>
  <source
    media="(min-width: 1024px)"
    srcset={desktop.srcSet.attribute}
    sizes="60vw"
  />
  <img
    src={mobile.src}
    srcset={mobile.srcSet.attribute}
    sizes="92vw"
    alt="Agent ubezpieczeniowy"
    width={mobile.attributes.width}
    height={mobile.attributes.height}
    loading="eager"
    fetchpriority="high"
    class="w-full h-full object-cover brightness-110 saturate-110"
  />
</picture>
