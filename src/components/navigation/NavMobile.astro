---
import { navLinks } from "../../data/navigation";
import { company } from "../../data/company";
import NavSocialIcons from "./NavSocialIcons.astro";

const phoneHref = `tel:${company.phone.replace(/\s/g, "")}`;
---

<div id="mobile-backdrop" class="mobile-backdrop"></div>

<nav id="mobile-menu" class="mobile-menu" aria-label="Menu mobilne">
  <div class="flex h-full flex-col px-6 pt-20 pb-8">
    <ul class="flex flex-col gap-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-lg font-medium"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-auto flex flex-col gap-6">
      <NavSocialIcons />

      <a
        href={phoneHref}
        class="inline-flex items-center justify-center gap-2 rounded-(--radius-md) border border-[#f59e0b]/55 bg-[#1a2332] px-6 py-3 font-semibold text-[#fbbf24] shadow-[0_0_18px_rgba(245,158,11,0.14),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#f59e0b]/80 hover:bg-[#243044] hover:text-[#fde68a] hover:shadow-[0_0_24px_rgba(245,158,11,0.2),0_4px_12px_rgba(0,0,0,0.3)]"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {company.phone}
      </a>
    </div>
  </div>
</nav>
