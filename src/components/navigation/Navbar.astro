---
import "../../styles/components/navbar.css";
import NavLinks from "./NavLinks.astro";
import NavSocialIcons from "./NavSocialIcons.astro";
import NavMobile from "./NavMobile.astro";
import NavbarScript from "../scripts/NavbarScript.astro";
import { company } from "../../data/company";
import PhoneButton from "../ui/PhoneButton.astro";
---

<header id="navbar" class="navbar">
  <div class="w-full">
    <nav class="navbar-card relative bg-(--color-bg-alt)/95 backdrop-blur-md overflow-hidden" aria-label="Menu główne">
      <!-- Noise texture -->
      <div class="surface-noise absolute inset-0 opacity-4 pointer-events-none"></div>

      <!-- Visible content row -->
      <div class="relative z-10 flex h-16 items-center justify-between px-6 sm:px-10 lg:px-12">
        <!-- Logo + nazwa firmy -->
        <a href="/" class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-(--radius-md) bg-(--color-accent)/10">
            <span class="font-heading text-lg font-bold text-(--color-accent)">L</span>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="font-heading text-lg font-bold text-(--color-text)">{company.name}</span>
            <span class="font-heading text-[0.72rem] font-medium uppercase tracking-[0.14em] text-(--color-text-light)">{company.tagline}</span>
          </div>
        </a>

        <!-- Desktop: linki + social + CTA -->
        <div class="hidden items-center gap-8 lg:flex">
          <NavLinks />
          <NavSocialIcons />

          <PhoneButton size="sm" />
        </div>

        <!-- Mobile: hamburger -->
        <button
          id="hamburger-btn"
          class="flex flex-col items-center justify-center gap-[5px] p-2 lg:hidden"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>

    </nav>
  </div>

  <NavMobile />
</header>

<NavbarScript />
