---
import { navLinks } from "../../data/navigation";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<ul class:list={["flex items-center gap-8", className]}>
  {
    navLinks.map((link) => (
      <li>
        <a href={link.href} class="nav-link">
          {link.label}
        </a>
      </li>
    ))
  }
</ul>
