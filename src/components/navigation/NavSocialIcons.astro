---
import { company } from "../../data/company";
import { socialLinks } from "../../data/navigation";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const socialUrls = {
  Facebook: company.social.facebook,
  Instagram: company.social.instagram,
  LinkedIn: company.social.linkedin,
} as const;

const socials = socialLinks
  .map((social) => ({
    ...social,
    url: socialUrls[social.name as keyof typeof socialUrls],
  }))
  .filter((social) => social.url);
---

{
  socials.length > 0 && (
    <div class:list={["flex items-center gap-3", className]}>
      {socials.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={social.name}
          class="text-(--color-text-light) hover:text-(--color-accent) transition-colors duration-200"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            set:html={social.icon}
          />
        </a>
      ))}
    </div>
  )
}
