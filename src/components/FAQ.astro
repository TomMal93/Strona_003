---
import "../styles/components/faq.css";
import SectionFrame from "./ui/SectionFrame.astro";
import { faqItems } from "../data/faq";
---

<SectionFrame id="faq" title="Najczęściej zadawane pytania" shellClass="faq-shell" headerClass="faq-section-header">
  <Fragment slot="icon">
    <svg viewBox="0 0 24 24">
      <path d="M9.09 9a3 3 0 1 1 5.82 1c0 2-3 3-3 3" />
      <path d="M12 17h.01" />
      <circle cx="12" cy="12" r="9" />
    </svg>
  </Fragment>

  <p slot="intro">
    Krótkie odpowiedzi na pytania, które najczęściej pojawiają się przed wyborem ubezpieczenia i rozpoczęciem współpracy z
    <strong>agentem PZU</strong>.<br />
    <span class="faq-section__highlight">Najważniejsze informacje znajdziesz od razu w jednym miejscu.</span>
  </p>

  <div class="faq-list">
    {faqItems.map((item) => (
      <details class="faq-item">
        <summary class="faq-item__summary">
          <h3 class="faq-item__question">{item.question}</h3>
          <span class="faq-item__trigger" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="faq-item__content">
          <p class="faq-item__answer">{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</SectionFrame>
