---
import { hero } from "../data/hero";
import { company } from "../data/company";

interface Props {
  variant: "mobile" | "desktop";
}

const { variant } = Astro.props;
const isMobile = variant === "mobile";
---

<div class:list={[
  isMobile
    ? "p-7 sm:p-10 text-center"
    : "p-10 lg:px-12 lg:py-14 xl:px-14 xl:py-16 text-left",
]}>
  <!-- Group 1: Accent bar + heading + description -->
  <div
    class="hero-delay-200 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100"
  >
    <p class="text-xs uppercase tracking-[0.2em] text-(--color-accent) font-semibold mb-4">
      {hero.tagline}
    </p>

    <div>
      <h1
        class:list={[
          "font-(family-name:--font-heading) font-bold leading-[1.08] text-white m-0 tracking-tight drop-shadow-lg",
          isMobile
            ? "text-[clamp(2.2rem,10vw,3.4rem)]"
            : "text-[clamp(2.25rem,3.5vw,3.75rem)]",
        ]}
        set:html={hero.title}
      />
      <p class:list={[
        "font-(family-name:--font-body) leading-[1.6] tracking-wide text-white/90 drop-shadow-sm",
        isMobile
          ? "mt-5 text-[clamp(1rem,4.2vw,1.15rem)] max-w-[32rem] mx-auto"
          : "mt-6 text-[clamp(1.05rem,1.5vw,1.3rem)] max-w-[540px]",
      ]}>
        {hero.description}
      </p>
    </div>
  </div>

  <div
    aria-hidden="true"
    class:list={[
      "hero-delay-400 h-px animate-[hero-fade-up_0.7s_ease-out_both] bg-gradient-to-r from-transparent via-[#f59e0b]/20 to-transparent motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile ? "mt-8 w-full" : "mt-10 w-full max-w-[540px]",
    ]}
  ></div>

  <!-- Group 2: Buttons -->
  <div
    class:list={[
      "hero-delay-400 mt-8 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile
        ? "flex flex-col gap-3 w-full"
        : "flex flex-row gap-5 items-center",
    ]}
  >
    <!-- Primary: matched to navbar CTA -->
    <a
      href={`tel:${company.phone.replace(/\s/g, "")}`}
      class="hero-btn-primary group relative inline-flex items-center justify-center gap-2.5 overflow-hidden rounded-(--radius-lg) bg-[#1c1508] px-8 py-4 text-lg font-semibold tracking-wide text-[#fbbf24] shadow-[0_0_18px_rgba(245,158,11,0.14),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#271e0c] hover:text-[#fde68a] hover:shadow-[0_0_24px_rgba(245,158,11,0.2),0_4px_12px_rgba(0,0,0,0.3)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent) cursor-pointer"
    >
      <span class="relative z-10 flex items-center gap-2.5">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {hero.actions.primary.label}
      </span>
    </a>

    <!-- Secondary: amber border glass -->
    <a
      href={hero.actions.secondary.href}
      class="group relative inline-flex items-center justify-center gap-2.5 rounded-(--radius-lg) border border-[#f59e0b]/42 bg-[#2a3447]/92 px-8 py-4 text-base font-medium tracking-wide text-white backdrop-blur-sm shadow-[0_0_14px_rgba(245,158,11,0.08),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#f59e0b]/72 hover:bg-[#344157] hover:text-white hover:shadow-[0_4px_22px_rgba(245,158,11,0.14)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
    >
      {hero.actions.secondary.label}
    </a>

    <!-- Tertiary: same as secondary -->
    <a
      href={hero.actions.tertiary.href}
      class="group relative inline-flex items-center justify-center gap-2.5 rounded-(--radius-lg) border border-[#f59e0b]/42 bg-[#2a3447]/92 px-8 py-4 text-base font-medium tracking-wide text-white backdrop-blur-sm shadow-[0_0_14px_rgba(245,158,11,0.08),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#f59e0b]/72 hover:bg-[#344157] hover:text-white hover:shadow-[0_4px_22px_rgba(245,158,11,0.14)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
    >
      {hero.actions.tertiary.label}
    </a>
  </div>

  <div
    aria-hidden="true"
    class:list={[
      "hero-delay-600 h-px animate-[hero-fade-up_0.7s_ease-out_both] bg-gradient-to-r from-transparent via-[#f59e0b]/20 to-transparent motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile ? "mt-8 w-full" : "mt-8 w-full max-w-[540px]",
    ]}
  ></div>

  <!-- Group 3: Trust badges -->
  <div
    class:list={[
      "hero-delay-600 mt-8 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile
        ? "flex flex-col items-center gap-3"
        : "flex flex-row items-center gap-x-6",
    ]}
  >
    {hero.trustBadges.map((badge) => (
      <div class="flex items-center gap-2 bg-white/5 rounded-(--radius-sm) px-3 py-1.5">
        <svg class="w-[18px] h-[18px] text-(--color-accent) shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-white/75 drop-shadow-sm">{badge.label}</span>
      </div>
    ))}
  </div>
</div>
