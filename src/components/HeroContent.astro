---
import { hero } from "../data/hero";

interface Props {
  variant: "mobile" | "desktop";
}

const { variant } = Astro.props;
const isMobile = variant === "mobile";
---

<div class:list={[
  isMobile
    ? "p-8 sm:p-10 text-center"
    : "p-10 lg:px-16 lg:py-14 xl:px-20 xl:py-16 text-left",
]}>
  <!-- Group 1: Accent bar + heading + description -->
  <div
    class="animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100"
    style="animation-delay: 0.2s"
  >
    {isMobile && (
      <div class="w-12 h-1 bg-(--color-accent) mx-auto mb-6"></div>
    )}

    <div class:list={[
      isMobile ? "" : "border-l-4 border-(--color-accent) pl-8",
    ]}>
      <h1
        class:list={[
          "font-(family-name:--font-heading) font-bold leading-[1.08] text-white m-0 tracking-tight drop-shadow-lg",
          isMobile
            ? "text-[clamp(2.2rem,10vw,3.4rem)]"
            : "text-[clamp(2.25rem,3.5vw,3.75rem)]",
        ]}
        set:html={hero.title}
      />
      <p class:list={[
        "leading-[1.7] text-white/80 drop-shadow-sm",
        isMobile
          ? "mt-5 text-[clamp(1rem,4.2vw,1.15rem)] max-w-[32rem] mx-auto"
          : "mt-6 text-[clamp(1.05rem,1.5vw,1.3rem)] max-w-[540px]",
      ]}>
        {hero.description}
      </p>
    </div>
  </div>

  <!-- Group 2: Buttons -->
  <div
    class:list={[
      "mt-10 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile
        ? "flex flex-col gap-3 w-full"
        : "flex flex-row gap-5 items-center",
    ]}
    style="animation-delay: 0.4s"
  >
    <!-- Primary: gradient glow + shimmer sweep -->
    <a
      href={hero.actions.primary.href}
      class="hero-btn-primary group relative inline-flex items-center justify-center gap-2.5 overflow-hidden rounded-(--radius-md) bg-gradient-to-r from-[#1e40af] via-[#2563eb] to-[#3b82f6] px-8 py-4 text-lg font-semibold text-white shadow-[0_0_24px_rgba(59,130,246,0.35)] transition-all duration-300 hover:shadow-[0_0_36px_rgba(59,130,246,0.55)] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-primary) cursor-pointer"
    >
      <span class="relative z-10 flex items-center gap-2.5">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {hero.actions.primary.label}
      </span>
      <span class="hero-shimmer absolute inset-0 z-0" aria-hidden="true"></span>
    </a>

    <!-- Secondary: glass morphism + arrow slide -->
    <a
      href={hero.actions.secondary.href}
      class="group relative inline-flex items-center justify-center gap-2.5 rounded-(--radius-md) border border-white/20 bg-white/8 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/15 hover:border-white/35 hover:-translate-y-0.5 hover:shadow-[0_4px_24px_rgba(255,255,255,0.08)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50 cursor-pointer"
    >
      {hero.actions.secondary.label}
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>

  <!-- Group 3: Trust badges -->
  <div
    class:list={[
      "mt-10 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100",
      isMobile
        ? "flex flex-col items-center gap-3"
        : "flex flex-row items-center gap-x-6",
    ]}
    style="animation-delay: 0.6s"
  >
    {hero.trustBadges.map((badge) => (
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-(--color-accent) shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-white/65 drop-shadow-sm">{badge.label}</span>
      </div>
    ))}
  </div>
</div>
