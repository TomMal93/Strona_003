---
import { Image } from "astro:assets";
import "../styles/components/contact.css";
import SectionFrame from "./ui/SectionFrame.astro";
import PhoneButton from "./ui/PhoneButton.astro";
import PrimaryButton from "./ui/PrimaryButton.astro";
import { company } from "../data/company";
import { about } from "../data/about";
import { contactSection } from "../data/contact";
import portraitImage from "../assets/contact.png";

const emailHref = `mailto:${company.email}`;
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${company.address.street}, ${company.address.zip} ${company.address.city}`,
)}`;
---

<SectionFrame id="porozmawiajmy" title={contactSection.title} shellClass="contact-shell">
  <Fragment slot="icon">
    <svg viewBox="0 0 24 24">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
  </Fragment>

  <Fragment slot="intro">
    <span>{contactSection.intro}</span>
    <span class="contact-intro__highlight">{contactSection.highlight}</span>
  </Fragment>

  <div class="contact-portrait-layout">
    <div class="contact-portrait-rail contact-portrait-rail--left">
      <div class="contact-channel contact-channel--bio">
        <div class="contact-contact-list__item">
          <div class="contact-contact-list__head">
            <div class="contact-channel__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="5" />
                <path d="M20 21a8 8 0 0 0-16 0" />
              </svg>
            </div>
            <div class="contact-contact-list__body">
              <strong>Pełna wizytówka</strong>
              <span>Poznaj mnie bliżej — doświadczenie, zakres usług i dane kontaktowe.</span>
            </div>
          </div>
          <PrimaryButton href="/o-mnie">Zobacz wizytówkę</PrimaryButton>
        </div>

        <blockquote class="contact-bio__quote">
          <p class="contact-bio__text">{about.sectionIntro}</p>
          <div class="contact-bio__header">
            <h3 class="contact-channel__title">{about.role}</h3>
            <p class="contact-bio__name">{about.name}</p>
          </div>
        </blockquote>

        <div class="contact-bio__hours">
          <p class="contact-bio__hours-title">{about.page.hoursTitle}</p>
          <div class="contact-bio__hours-grid">
            {about.page.hoursRows.map((row) => (
              <div class="contact-bio__hours-card">
                <span class="contact-bio__hours-day">{row.day}</span>
                <span class="contact-bio__hours-value">{row.hours}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

    <div class="contact-portrait">
      <div class="contact-portrait__ring">
        <div class="contact-portrait__frame">
          <Image
            src={portraitImage}
            alt="Agent ubezpieczeniowy"
            class="contact-portrait__image"
            width={1184}
            height={2153}
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <div class="contact-portrait-rail contact-portrait-rail--right">
      <div class="contact-channel contact-channel--stack" data-delay="80">
        <ul class="contact-contact-list">
          <li class="contact-contact-list__item">
            <div class="contact-contact-list__head">
              <div class="contact-channel__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <rect width="20" height="16" x="2" y="4" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              </div>
              <div class="contact-contact-list__body">
                <strong>{contactSection.channels.email.title}</strong>
                <span>{contactSection.channels.email.desc}</span>
              </div>
            </div>
            <PrimaryButton href={emailHref}>{contactSection.channels.email.cta}</PrimaryButton>
          </li>

          <li class="contact-contact-list__item">
            <div class="contact-contact-list__head">
              <div class="contact-channel__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <div class="contact-contact-list__body">
                <strong>{contactSection.channels.phone.title}</strong>
                <span>{contactSection.channels.phone.desc}</span>
              </div>
            </div>
            <PhoneButton size="lg" showSubtext subtextLabel="Zadzwoń teraz" />
          </li>

          <li class="contact-contact-list__item">
            <div class="contact-contact-list__head">
              <div class="contact-channel__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div class="contact-contact-list__body">
                <strong>{contactSection.channels.visit.title}</strong>
                <span>{contactSection.channels.visit.desc}</span>
              </div>
            </div>
            <PrimaryButton href={mapsHref}>{contactSection.channels.visit.cta}</PrimaryButton>
          </li>

        </ul>
      </div>
    </div>
  </div>

  {contactSection.reassurance && (
    <div class="contact-closing">
      <p class="contact-closing__reassurance" set:html={contactSection.reassurance} />
    </div>
  )}
</SectionFrame>

<script>
  import { initContactReveal } from "../scripts/contact-reveal";
  initContactReveal();
</script>
