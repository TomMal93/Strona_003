---
import HeroBackground from "./HeroBackground.astro";
import HeroDesktop from "./HeroDesktop.astro";
import HeroMobile from "./HeroMobile.astro";
---

<section class="min-h-screen flex items-center justify-center px-4 py-12 overflow-hidden">
    <div class="relative w-[92vw] h-[85vh]">
      <!-- Subtle glow behind card -->

      <!-- Card -->
      <div class="hero-card relative h-full bg-[#111827] border border-[#f59e0b]/15 rounded-(--radius-lg) overflow-hidden flex flex-col lg:flex-row animate-[hero-card-enter_0.8s_ease-out_both] motion-reduce:animate-none">

        <!-- Noise texture on card -->
        <div class="hero-noise absolute inset-0 opacity-4 pointer-events-none rounded-(--radius-lg)"></div>

        <!-- Mobile: image on top -->
        <div class="lg:hidden">
          <HeroBackground variant="mobile" />
        </div>

        <!-- Desktop: full-bleed image with gradient over left side for text readability -->
        <div class="hidden lg:block absolute inset-0">
          <HeroBackground variant="desktop" />
          <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/95 from-25% via-[#111827]/60 via-45% to-transparent z-10"></div>
        </div>

        <!-- Content (left on desktop, below image on mobile) -->
        <div class="flex-1 relative z-20 h-full">
          <HeroMobile />
          <HeroDesktop />
        </div>

      </div>
    </div>
</section>

<style>
  .hero-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* Shimmer sweep across primary button */
  .hero-shimmer {
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.18) 45%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.18) 55%,
      transparent 60%
    );
    background-size: 250% 100%;
    background-position: 100% 0;
  }

  .hero-card {
    box-shadow:
      0 0 60px rgba(245,158,11,0.45),
      0 0 120px rgba(245,158,11,0.35),
      0 0 250px rgba(245,158,11,0.2),
      0 4px 60px rgba(0,0,0,0.4);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-card {
      animation: hero-card-enter 0.8s ease-out both, halo-pulse 4s ease-in-out 1s infinite;
    }
    @keyframes halo-pulse {
      0%, 100% {
        box-shadow:
          0 0 60px rgba(245,158,11,0.45),
          0 0 120px rgba(245,158,11,0.35),
          0 0 250px rgba(245,158,11,0.2),
          0 4px 60px rgba(0,0,0,0.4);
      }
      50% {
        box-shadow:
          0 0 90px rgba(245,158,11,0.6),
          0 0 180px rgba(245,158,11,0.45),
          0 0 320px rgba(245,158,11,0.25),
          0 4px 60px rgba(0,0,0,0.4);
      }
    }
    .hero-shimmer {
      animation: shimmer-sweep 4s ease-in-out 1.5s infinite;
    }
    @keyframes shimmer-sweep {
      0%   { background-position: 100% 0; }
      30%  { background-position: -50% 0; }
      100% { background-position: -50% 0; }
    }
    .hero-btn-primary:hover .hero-shimmer {
      animation: none;
      background-position: -50% 0;
      opacity: 0;
      transition: opacity 0.3s;
    }
  }
</style>
