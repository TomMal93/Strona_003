---
import Button from "./ui/Button.astro";
import Container from "./ui/Container.astro";
---

<section class="hero">
  <img
    src="/images/hero-bg.jpg"
    alt="Biuro agenta ubezpieczeniowego"
    width="1920"
    height="1080"
    loading="lazy"
    class="hero__bg"
  />
  <div class="hero__overlay"></div>
  <div class="hero__noise"></div>

  <Container class="hero__content">
    <h1 class="hero__title">
      Ubezpieczenia dopasowane<br />do Twojej sytuacji
    </h1>
    <p class="hero__description">
      Pomagam dobrać ochronę, która ma sens — dla Ciebie, Twojej rodziny
      i Twojego majątku. Bez zbędnych polis, bez przepłacania.
    </p>
    <div class="hero__actions">
      <Button href="#kontakt" variant="primary">Umów konsultację</Button>
      <Button href="#oferta" variant="secondary">Zobacz ofertę</Button>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(10, 15, 36, 0.82) 0%,
      rgba(10, 15, 36, 0.72) 50%,
      rgba(10, 15, 36, 0.88) 100%
    );
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    padding-block: 6rem 4rem;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero__description {
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.78);
    max-width: 580px;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2.5rem;
    width: 100%;
    max-width: 320px;
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      max-width: none;
      width: auto;
      gap: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg {
      transition: none;
    }
  }
</style>
