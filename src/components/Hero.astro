---
import HeroBackground from "./HeroBackground.astro";
import HeroDesktop from "./HeroDesktop.astro";
import HeroMobile from "./HeroMobile.astro";
---

<section class="min-h-screen flex items-center justify-center px-4 py-12 overflow-hidden">
    <div class="relative w-[92vw] h-[85vh]">
      <!-- Subtle glow behind card -->

      <!-- Card -->
      <div class="hero-card relative h-full bg-[#111827] border border-[#f59e0b]/15 rounded-(--radius-lg) overflow-hidden flex flex-col lg:flex-row animate-[hero-card-enter_0.8s_ease-out_both] motion-reduce:animate-none">

        <!-- Noise texture on card -->
        <div class="hero-noise absolute inset-0 opacity-4 pointer-events-none rounded-(--radius-lg)"></div>

        <!-- Mobile: image on top -->
        <div class="lg:hidden">
          <HeroBackground variant="mobile" />
        </div>

        <!-- Desktop: full-bleed image with gradient over left side for text readability -->
        <div class="hidden lg:block absolute inset-0">
          <HeroBackground variant="desktop" />
          <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/82 from-22% via-[#111827]/42 via-40% to-transparent z-10"></div>
        </div>

        <!-- Content (left on desktop, below image on mobile) -->
        <div class="flex-1 relative z-20 h-full">
          <HeroMobile />
          <HeroDesktop />
        </div>

      </div>
    </div>
</section>
