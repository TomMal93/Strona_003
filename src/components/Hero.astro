---
import { hero } from "../data/hero";
import { company } from "../data/company";
import HeroBackground from "./HeroBackground.astro";
import HeroStatCard from "./HeroStatCard.astro";
---

<section class="min-h-screen flex flex-col items-center justify-center px-4 py-12 overflow-hidden">
  <!-- Bento grid -->
  <div class="hero-bento-grid w-[96vw] max-w-[1650px]">

    <!-- Text + Highlights + CTA card -->
    <div class="hero-bento-card hero-bento-text relative overflow-hidden animate-[hero-card-enter_0.8s_ease-out_both] motion-reduce:animate-none">
      <div class="hero-noise absolute inset-0 opacity-4 pointer-events-none rounded-(--radius-lg)"></div>

      <div class="relative z-10 p-7 sm:p-10 lg:p-12 xl:p-14 flex flex-col h-full">
        <!-- Header -->
        <div class="mt-auto hero-delay-200 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100">
          <p class="text-xs uppercase tracking-[0.2em] text-(--color-accent) font-semibold mb-4">
            {hero.tagline}
          </p>

          <h1
            class="font-(family-name:--font-heading) font-bold leading-[1.08] text-white m-0 tracking-tight drop-shadow-lg text-[clamp(2rem,4vw,3.5rem)]"
            set:html={hero.title}
          />

          <blockquote class="mt-[25px] lg:mt-[41px] pl-4 border-l-2 border-[#f59e0b]/30 font-(family-name:--font-heading) italic leading-[1.7] tracking-wide text-white/80 text-[clamp(0.85rem,1.2vw,1.05rem)] w-full"
            set:html={`\u201E${hero.description}\u201D`}
          />
        </div>

        <!-- Separator -->
        <div
          aria-hidden="true"
          class="hero-delay-300 mt-6 h-px w-full max-w-[540px] animate-[hero-fade-up_0.7s_ease-out_both] bg-gradient-to-r from-transparent via-[#f59e0b]/20 to-transparent motion-reduce:animate-none motion-reduce:opacity-100"
        ></div>

        <!-- Highlights -->
        <div class="hero-delay-400 my-auto translate-y-[150px] animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100 grid grid-cols-3 items-center">
          {hero.highlights.map((text, i) => (
            <div class:list={["hero-stat flex items-center justify-center text-center py-2 px-3 lg:py-3 lg:px-4", { "hero-stat--bordered": i < hero.highlights.length - 1 }]}>
              <span class="font-(family-name:--font-heading) text-xs lg:text-sm font-semibold text-[#f59e0b]/80 leading-tight tracking-wide">
                {text}
              </span>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="hero-delay-600 mt-auto animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100 flex flex-col sm:flex-row gap-3 sm:gap-4 items-stretch sm:items-center sm:justify-center">
          <a
            href={`tel:${company.phone.replace(/\s/g, "")}`}
            class="group inline-flex items-center justify-center gap-2.5 rounded-(--radius-lg) border border-[#f59e0b]/30 bg-[#f59e0b]/10 px-6 py-3 text-sm font-semibold tracking-wide text-[#f59e0b] transition-all duration-300 hover:bg-[#f59e0b]/18 hover:border-[#f59e0b]/50 hover:text-[#fde68a] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent) cursor-pointer"
          >
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span class="flex flex-col items-start leading-tight">
              <span>{hero.actions.primary.label}</span>
              <span class="text-[0.65rem] font-normal text-[#f59e0b]/50 tracking-wider">{company.phone}</span>
            </span>
          </a>

          <a
            href={hero.actions.secondary.href}
            class="group inline-flex items-center justify-center rounded-(--radius-lg) border border-white/12 px-6 py-3 text-sm font-medium tracking-wide text-white/70 transition-all duration-300 hover:border-white/25 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
          >
            {hero.actions.secondary.label}
          </a>

          <a
            href={hero.actions.tertiary.href}
            class="group inline-flex items-center justify-center rounded-(--radius-lg) border border-white/12 px-6 py-3 text-sm font-medium tracking-wide text-white/70 transition-all duration-300 hover:border-white/25 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
          >
            {hero.actions.tertiary.label}
          </a>
        </div>
      </div>
    </div>

    <!-- Image card -->
    <div class="hero-bento-card hero-bento-image relative animate-[hero-card-enter_0.8s_ease-out_both] hero-delay-200 motion-reduce:animate-none">
      <div class="hero-bento-image__media">
        <HeroBackground variant="desktop" />
        <div class="hero-image-overlay pointer-events-none absolute inset-0"></div>

        <div class="hero-advisor-status absolute right-4 top-4 z-20 sm:right-5 sm:top-5 lg:right-6 lg:top-6">
          <span class="hero-advisor-status__dot" aria-hidden="true"></span>
          {hero.advisorCard.availability}
        </div>
      </div>

      <div class="hero-advisor-panel">
        <div class="hero-advisor-panel__main">
          <div class="hero-advisor-panel__info">
            <div class="hero-advisor-panel__header">
              <p class="hero-advisor-panel__eyebrow">Autoryzowany agent <img src="/images/pzu-logo.svg" alt="PZU" class="hero-advisor-panel__logo" /></p>
              <p class="hero-advisor-panel__role">{hero.advisorCard.role}</p>
            </div>

            <div class="hero-advisor-panel__specialties">
              {hero.advisorCard.specialties.map((specialty) => (
                <span class="hero-advisor-panel__pill">{specialty}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- City names -->
  <div class="hero-cities" aria-hidden="true">
    <span>KRASNYSTAW</span>
    <span class="hero-cities__dot">·</span>
    <span>ZAMOŚĆ</span>
    <span class="hero-cities__dot">·</span>
    <span>CHEŁM</span>
    <span class="hero-cities__dot">·</span>
    <span>LUBLIN</span>
  </div>
</section>
