---
import HeroBackground from "./HeroBackground.astro";
import HeroDesktop from "./HeroDesktop.astro";
import HeroMobile from "./HeroMobile.astro";
---

<section class="relative flex min-h-screen items-center overflow-hidden">
  <HeroBackground />
  <div class="hero-noise absolute inset-0 z-1 opacity-4 pointer-events-none"></div>
  <HeroMobile />
  <HeroDesktop />
</section>

<style>
  .hero-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }
</style>
