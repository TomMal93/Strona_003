---
import { hero } from "../data/hero";
import { company } from "../data/company";
import HeroBackground from "./HeroBackground.astro";
import HeroStatCard from "./HeroStatCard.astro";
---

<section class="min-h-screen flex flex-col items-center justify-center px-4 py-12 overflow-hidden">
  <!-- Bento grid -->
  <div class="hero-bento-grid w-[96vw] max-w-[1650px]">

    <!-- Text + CTA card -->
    <div class="hero-bento-card hero-bento-text relative overflow-hidden animate-[hero-card-enter_0.8s_ease-out_both] motion-reduce:animate-none">
      <div class="hero-noise absolute inset-0 opacity-4 pointer-events-none rounded-(--radius-lg)"></div>

      <div class="relative z-10 p-7 sm:p-10 lg:p-12 xl:p-14 flex flex-col h-full">
        <div class="mt-auto hero-delay-200 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100">
          <p class="text-xs uppercase tracking-[0.2em] text-(--color-accent) font-semibold mb-4">
            {hero.tagline}
          </p>

          <h1
            class="font-(family-name:--font-heading) font-bold leading-[1.08] text-white m-0 tracking-tight drop-shadow-lg text-[clamp(2rem,4vw,3.5rem)]"
            set:html={hero.title}
          />

          <p class="mt-5 lg:mt-6 font-(family-name:--font-body) leading-[1.6] tracking-wide text-white/90 drop-shadow-sm text-[clamp(1rem,1.4vw,1.25rem)] max-w-[540px]">
            {hero.description}
          </p>
        </div>

        <div
          aria-hidden="true"
          class="hero-delay-400 mt-4 h-px w-full max-w-[540px] animate-[hero-fade-up_0.7s_ease-out_both] bg-gradient-to-r from-transparent via-[#f59e0b]/20 to-transparent motion-reduce:animate-none motion-reduce:opacity-100"
        ></div>

        <!-- Buttons -->
        <div class="hero-delay-400 mt-auto mb-2 animate-[hero-fade-up_0.7s_ease-out_both] motion-reduce:animate-none motion-reduce:opacity-100 flex flex-col sm:flex-row gap-3 sm:gap-5 items-stretch sm:items-center sm:justify-center">
          <a
            href={`tel:${company.phone.replace(/\s/g, "")}`}
            class="hero-btn-primary group relative inline-flex items-center justify-center gap-2.5 overflow-hidden rounded-(--radius-lg) bg-[#1c1508] px-8 py-4 text-lg font-semibold tracking-wide text-[#fbbf24] shadow-[0_0_18px_rgba(245,158,11,0.14),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#271e0c] hover:text-[#fde68a] hover:shadow-[0_0_24px_rgba(245,158,11,0.2),0_4px_12px_rgba(0,0,0,0.3)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent) cursor-pointer"
          >
            <span class="relative z-10 flex items-center gap-2.5">
              <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <span class="flex flex-col items-start leading-tight">
                <span>{hero.actions.primary.label}</span>
                <span class="text-xs font-normal text-[#fbbf24]/70 tracking-wider">{company.phone}</span>
              </span>
            </span>
          </a>

          <a
            href={hero.actions.secondary.href}
            class="group relative inline-flex items-center justify-center gap-2.5 rounded-(--radius-lg) border border-[#f59e0b]/42 bg-[#2a3447]/92 px-8 py-4 text-base font-medium tracking-wide text-white backdrop-blur-sm shadow-[0_0_14px_rgba(245,158,11,0.08),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#f59e0b]/72 hover:bg-[#344157] hover:text-white hover:shadow-[0_4px_22px_rgba(245,158,11,0.14)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
          >
            {hero.actions.secondary.label}
          </a>

          <a
            href={hero.actions.tertiary.href}
            class="group relative inline-flex items-center justify-center gap-2.5 rounded-(--radius-lg) border border-[#f59e0b]/42 bg-[#2a3447]/92 px-8 py-4 text-base font-medium tracking-wide text-white backdrop-blur-sm shadow-[0_0_14px_rgba(245,158,11,0.08),0_2px_8px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#f59e0b]/72 hover:bg-[#344157] hover:text-white hover:shadow-[0_4px_22px_rgba(245,158,11,0.14)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)/50 cursor-pointer"
          >
            {hero.actions.tertiary.label}
          </a>
        </div>

      </div>
    </div>

    <!-- Stats -->
    <div class="hero-bento-stats animate-[hero-card-enter_0.8s_ease-out_both] hero-delay-600 motion-reduce:animate-none grid grid-cols-3 h-full items-center">
      {hero.stats.map((stat, i) => (
        <div class:list={["hero-stat flex flex-col items-center justify-center text-center py-3 px-4 lg:py-4 lg:px-5", { "hero-stat--bordered": i < hero.stats.length - 1 }]}>
          <span class="font-(family-name:--font-heading) text-lg lg:text-xl font-bold text-[#f59e0b] leading-none">
            {stat.value}
          </span>
          <span class="mt-1.5 text-[0.65rem] text-white/50 leading-tight">
            {stat.label}
          </span>
        </div>
      ))}
    </div>

    <!-- Image card -->
    <div class="hero-bento-card hero-bento-image relative animate-[hero-card-enter_0.8s_ease-out_both] hero-delay-200 motion-reduce:animate-none">
      <div class="hero-bento-image__media">
        <HeroBackground variant="desktop" />
        <div class="hero-image-overlay pointer-events-none absolute inset-0"></div>

        <div class="hero-advisor-status absolute right-4 top-4 z-20 sm:right-5 sm:top-5 lg:right-6 lg:top-6">
          <span class="hero-advisor-status__dot" aria-hidden="true"></span>
          {hero.advisorCard.availability}
        </div>
      </div>

      <div class="hero-advisor-panel">
        <div class="hero-advisor-panel__main">
          <div class="hero-advisor-panel__info">
            <div class="hero-advisor-panel__header">
              <p class="hero-advisor-panel__eyebrow">{hero.tagline}</p>
              <p class="hero-advisor-panel__role">{hero.advisorCard.role}</p>
            </div>

            <div class="hero-advisor-panel__chips">
              {hero.advisorCard.specialties.map((specialty) => (
                <span class="hero-advisor-panel__chip">{specialty}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- City names -->
  <div class="hero-cities" aria-hidden="true">
    <span>KRASNYSTAW</span>
    <span class="hero-cities__dot">·</span>
    <span>ZAMOŚĆ</span>
    <span class="hero-cities__dot">·</span>
    <span>CHEŁM</span>
    <span class="hero-cities__dot">·</span>
    <span>LUBLIN</span>
  </div>
</section>
