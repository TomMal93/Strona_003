---
import { Image } from "astro:assets";
import Button from "./ui/Button.astro";
import Container from "./ui/Container.astro";
import { hero } from "../data/hero";
import heroMainImage from "../assets/hero-main-image.webp";
---

<section class="relative flex items-center min-h-screen overflow-hidden">
  <Image
    src={heroMainImage}
    alt="Biuro agenta ubezpieczeniowego"
    widths={[480, 768, 1024, 1376]}
    sizes="100vw"
    quality={75}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover z-0 motion-reduce:transition-none"
  />
  <div class="hero-noise absolute inset-0 z-1 opacity-4 pointer-events-none"></div>

  <Container
    class="relative z-2 flex flex-col items-center text-center max-w-[720px] mx-auto py-24 pb-16"
  >
    <h1
      class="font-(family-name:--font-heading) text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.15] text-white m-0 tracking-tight"
    >
      {hero.title}
    </h1>
    <p
      class="mt-6 text-[clamp(1rem,2vw,1.25rem)] leading-[1.7] text-white/78 max-w-[580px]"
    >
      {hero.description}
    </p>
    <div
      class="flex flex-col gap-3 mt-10 w-full max-w-80 sm:flex-row sm:max-w-none sm:w-auto sm:gap-4"
    >
      <Button href={hero.actions.primary.href} variant="primary">
        {hero.actions.primary.label}
      </Button>
      <Button href={hero.actions.secondary.href} variant="secondary">
        {hero.actions.secondary.label}
      </Button>
    </div>
  </Container>
</section>

<style>
  .hero-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }
</style>
