---
import HeroContent from "./HeroContent.astro";
---

<div class="hidden md:block">
  <HeroContent
    containerClass="relative z-2 max-w-[720px] mx-auto py-24 pb-16"
    contentClass="flex flex-col items-center text-center"
    titleClass="font-(family-name:--font-heading) text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.15] text-white m-0 tracking-tight"
    descriptionClass="mt-6 text-[clamp(1rem,2vw,1.25rem)] leading-[1.7] text-white/78 max-w-[580px]"
    actionsClass="flex flex-col gap-3 mt-10 w-full max-w-80 sm:flex-row sm:max-w-none sm:w-auto sm:gap-4"
  />
</div>
