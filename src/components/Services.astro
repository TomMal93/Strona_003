---
import "../styles/components/services.css";
import Button from "./ui/Button.astro";
import SectionFrame from "./ui/SectionFrame.astro";
import ServicesRevealScript from "./scripts/ServicesRevealScript.astro";
import { services, servicesClosingNote } from "../data/services";
---

<SectionFrame id="oferta" title="Oferta" shellClass="services-shell">
  <Fragment slot="icon">
    <svg viewBox="0 0 24 24">
      <path d="M7 6.75h10" />
      <path d="M7 12h10" />
      <path d="M7 17.25h6" />
      <path d="M4.75 6.75h.5" />
      <path d="M4.75 12h.5" />
      <path d="M4.75 17.25h.5" />
    </svg>
  </Fragment>

  <p slot="intro">
    Oferuję ubezpieczenia <strong>PZU w&nbsp;Krasnymstawie i&nbsp;okolicy</strong>, pomagając dobrać ochronę
    dopasowaną do codziennych potrzeb <strong>klientów indywidualnych, rodzin oraz firm</strong>.
  </p>

  <div class="services-grid">
    {services.map((service, i) => (
      <div
        class="service-card"
        data-delay={i * 100}
        data-service={service.title === "Zdrowotne" ? "health" : service.title === "Firmowe" ? "business" : "default"}
      >
        <div class="service-card__glow"></div>
        {service.badge && (
          <span class="service-card__badge">{service.badge}</span>
        )}
        <div class="service-card__decor"></div>

        <div class="service-card__header">
          <div class="service-card__icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <Fragment set:html={service.icon} />
            </svg>
          </div>
          <div class="service-card__titles">
            <div class="service-card__title-row">
              <h3 class="service-card__title">{service.title}</h3>
            </div>
            <p class="service-card__subtitle">{service.subtitle}</p>
          </div>
        </div>

        <p class="service-card__desc">{service.description}</p>

        <div class="service-card__divider"></div>

        <ul class="service-card__features">
          {service.features.map((feature) => (
            <li class="service-card__feature">
              <span class="service-card__check">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="service-card__feature-label">{feature}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <p class="services-section__closing-note" set:html={servicesClosingNote.text} />

  <div class="services-section__actions">
    <Button href="/oferta" variant="accent" class="group">
      Zobacz pełną ofertę
    </Button>
  </div>
</SectionFrame>

<ServicesRevealScript />
