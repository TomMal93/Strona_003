---
import { company, phoneHref } from "../../data/company";

interface Props {
  size?: "sm" | "lg";
  showSubtext?: boolean;
  subtextLabel?: string;
  mobileSubtextLabel?: string;
  class?: string;
}

const {
  size = "sm",
  showSubtext = false,
  subtextLabel,
  mobileSubtextLabel,
  class: className,
} = Astro.props;

const sizeClasses = {
  sm: "inline-flex items-center gap-2 rounded-(--radius-md) bg-(--color-accent)/10 px-5 py-2 font-heading text-[0.95rem] font-semibold tracking-[0.04em] text-(--color-accent-light) transition-colors duration-300 hover:bg-(--color-accent)/18 hover:text-(--color-accent-pale)",
  lg: "inline-flex items-center justify-center gap-3 rounded-(--radius-lg) border border-(--color-accent)/30 bg-(--color-accent)/10 px-7 py-3 text-base font-semibold tracking-wide text-(--color-accent) transition-all duration-300 hover:bg-(--color-accent)/18 hover:border-(--color-accent)/50 hover:text-(--color-accent-pale) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent) cursor-pointer",
} as const;

const iconClasses = size === "lg"
  ? "h-5 w-5 transition-transform duration-300 group-hover:rotate-12"
  : "h-4 w-4";

const classes = [sizeClasses[size], className]
  .filter(Boolean)
  .join(" ");
---

<a href={phoneHref} class={classes}>
  <svg class={iconClasses} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
  </svg>

  {showSubtext ? (
    <span class="flex flex-col items-start leading-[1.05]">
      {subtextLabel && !mobileSubtextLabel && <span>{subtextLabel}</span>}
      {subtextLabel && mobileSubtextLabel && (
        <>
          <span class="hidden sm:inline">{subtextLabel}</span>
          <span class="sm:hidden">{mobileSubtextLabel}</span>
        </>
      )}
      <span class="mt-0.5 text-[0.72rem] font-normal text-(--color-accent)/58 tracking-wider">{company.phone}</span>
    </span>
  ) : (
    <span>{company.phone}</span>
  )}
</a>
