---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="hero-bento-card flex flex-col items-center justify-center text-center p-4 lg:p-5">
  <span class="font-(family-name:--font-heading) text-2xl lg:text-3xl font-bold text-(--color-accent) leading-none">
    {value}
  </span>
  <span class="mt-1.5 text-xs lg:text-sm text-white/70 leading-tight">
    {label}
  </span>
</div>
